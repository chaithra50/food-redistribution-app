# Production Environment Variables
# Set these in Heroku Config Vars via: heroku config:set KEY=VALUE

# MongoDB Atlas Connection String (use MongoDB Atlas, not localhost)
# Example: mongodb+srv://username:password@cluster.mongodb.net/foodlink?retryWrites=true&w=majority
MONGO_URI=your_mongodb_atlas_uri_here

# JWT Secret for token signing
JWT_SECRET=your_secure_jwt_secret_key

# Node environment
NODE_ENV=production

# Port (Heroku assigns this automatically, but include for reference)
PORT=5000
